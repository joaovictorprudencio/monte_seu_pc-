<p class="notice"><%= notice %></p>

<div class="container">
  <div class="card">

    <div class="card-header">
      <h1>Detalhes da montagem</h1>
    </div>

    <div class="card-body">
      <%= render @computer %>
    </div>

    <div class="card-footer">
      <div class="actions-left">
        <%= link_to "← Voltar", computers_path, class: "btn btn-secondary" %>
      </div>

      <div class="actions-right">
        <%= link_to "Editar", edit_computer_path(@computer), class: "btn btn-primary" %>

        <%= button_to "Excluir", @computer, method: :delete, class: "btn btn-info", data: { confirm: "Tem certeza?" } %>
        <button type="button" class="btn btn-primary">Botão Bootstrap</button>

        
      </div>
    </div>

  </div>
</div>